# Copiá este archivo como .env y completá los valores desde tu proyecto Supabase
# Settings → API → Project URL y anon/public key

SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Settings → API → service_role key (nunca exponer en el frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

PORT=3000

# ── Mercado Pago ──────────────────────────────────────────────────
# Access Token de tu app — Developers panel → Tu app → Credenciales
# Usá las TEST-* para desarrollo y las APP_USR-* para producción.
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxx

# Precio mensual del plan Pro en ARS (default: 15000)
MERCADOPAGO_PRO_PRICE_ARS=15000

# URL pública del frontend (para back_url al volver del checkout de MP)
APP_URL=https://nume-lovat.vercel.app
